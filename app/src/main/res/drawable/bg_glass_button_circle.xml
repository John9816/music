<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="?attr/rippleColor">
    <item android:id="@android:id/mask">
        <shape android:shape="oval">
            <solid android:color="@android:color/white" />
        </shape>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <solid android:color="?attr/surfaceAltColor" />
                    <stroke
                        android:width="1dp"
                        android:color="?attr/dividerColor" />
                </shape>
            </item>
            <item
                android:left="6dp"
                android:top="4dp"
                android:right="6dp"
                android:bottom="10dp">
                <shape android:shape="oval">
                    <solid android:color="?attr/brandPrimaryLight" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
