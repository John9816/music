<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/surfaceColor" />
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="?attr/dividerColor" />
        </shape>
    </item>

    <item
        android:gravity="top"
        android:height="2dp"
        android:left="28dp"
        android:right="28dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="?attr/brandPrimaryLight" />
            <corners android:radius="1dp" />
        </shape>
    </item>
</layer-list>
