<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/glassSurfaceStrong" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="?attr/glassStrokeSoft" />
        </shape>
    </item>

    <item
        android:gravity="top"
        android:height="2dp"
        android:left="24dp"
        android:right="24dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="?attr/glassHighlight" />
            <corners android:radius="1dp" />
        </shape>
    </item>
</layer-list>

