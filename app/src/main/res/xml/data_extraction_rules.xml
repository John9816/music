<?xml version="1.0" encoding="utf-8"?>
<!-- 用于 API 31 及以上的云备份与设备转移规则 -->
<data-extraction-rules>
    <cloud-backup>
        <!-- 排除加密的登录凭据：master key 绑定当前设备，恢复到新设备无法解密 -->
        <exclude domain="sharedpref" path="auth_prefs_secure.xml" />
        <exclude domain="sharedpref" path="auth_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="auth_prefs_secure.xml" />
        <exclude domain="sharedpref" path="auth_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
