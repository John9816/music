<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MusicPlayer" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/brand_primary_light</item>
        <item name="colorOnPrimaryContainer">@color/brand_primary_dark</item>

        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_alt</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/divider</item>

        <item name="android:colorBackground">@color/page_background</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <item name="textInputOutlinedStyle">@style/Widget.MusicPlayer.TextField</item>
        <item name="materialCardViewOutlinedStyle">@style/Widget.MusicPlayer.Card.Outlined</item>
        <item name="materialButtonStyle">@style/Widget.MusicPlayer.Button.Primary</item>

        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Material3.MaterialAlertDialog</item>

        <item name="android:windowBackground">@color/page_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>

    </style>
</resources>
