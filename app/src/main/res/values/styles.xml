<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.MusicPlayer.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">?attr/surfaceColor</item>
        <item name="cardCornerRadius">@dimen/radius_l</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/dividerColor</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.MusicPlayer.TextField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_l</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_l</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_l</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_l</item>
        <item name="boxBackgroundColor">?attr/surfaceAltColor</item>
        <item name="boxStrokeColor">@color/text_field_stroke_color</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="android:textColorHint">?attr/textSecondary</item>
        <item name="hintTextColor">?attr/textSecondary</item>
        <item name="startIconTint">?attr/textSecondary</item>
        <item name="endIconTint">?attr/textSecondary</item>
    </style>

    <style name="Widget.MusicPlayer.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/radius_l</item>
        <item name="android:minHeight">@dimen/control_height_l</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">?attr/brandPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="iconTint">?attr/colorOnPrimary</item>
        <item name="rippleColor">?attr/brandPrimaryLight</item>
    </style>

    <style name="Widget.MusicPlayer.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/radius_l</item>
        <item name="android:minHeight">@dimen/control_height_l</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">?attr/surfaceAltColor</item>
        <item name="strokeColor">?attr/dividerColor</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">?attr/textPrimary</item>
        <item name="iconTint">?attr/textPrimary</item>
        <item name="rippleColor">?attr/brandPrimaryLight</item>
    </style>

    <style name="TextAppearance.MusicPlayer.Eyebrow" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.MusicPlayer.SectionTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.MusicPlayer.HeroTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="ShapeAppearanceOverlayMusicPlayerCircle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearanceOverlayMusicPlayerBottomSheetNoCorners">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">0dp</item>
    </style>

    <style name="WidgetMusicPlayerBottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlayMusicPlayerBottomSheetNoCorners</item>
    </style>

    <style name="ThemeOverlayMusicPlayerFullscreenBottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/WidgetMusicPlayerBottomSheet</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="ThemeOverlayMusicPlayerFullscreenDialog" parent="Theme.MusicPlayer">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
