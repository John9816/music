<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:paddingTop="@dimen/spacing_s">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/spacing_sm">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardBackgroundColor="?attr/surfaceColor"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/dividerColor"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/item_song_name_placeholder"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note_24"
                android:tint="?attr/brandPrimary" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvSongName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_m"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/item_song_name_placeholder"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="?attr/textPrimary"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btnMore"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintTop_toTopOf="@id/iconContainer" />

        <TextView
            android:id="@+id/tvArtist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_m"
            android:layout_marginTop="@dimen/spacing_xs"
            android:layout_marginEnd="@dimen/spacing_s"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/item_artist_placeholder"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/textSecondary"
            app:layout_constraintEnd_toStartOf="@id/tvDuration"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintTop_toBottomOf="@id/tvSongName" />

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_s"
            android:text="00:00"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="?attr/textSecondary"
            app:layout_constraintBaseline_toBaselineOf="@id/tvArtist"
            app:layout_constraintEnd_toStartOf="@id/btnMore" />

        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_more"
            android:padding="4dp"
            android:src="@drawable/ic_more_vert_24"
            android:tint="?attr/textSecondary"
            app:layout_constraintBottom_toBottomOf="@id/iconContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iconContainer" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="64dp"
        android:alpha="0.72"
        android:background="?attr/colorOutline" />
</LinearLayout>

