<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_song_item"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minHeight="@dimen/song_row_min_height"
    android:orientation="horizontal"
    android:paddingStart="@dimen/spacing_xs"
    android:paddingTop="@dimen/song_row_vertical_padding"
    android:paddingEnd="0dp"
    android:paddingBottom="@dimen/song_row_vertical_padding">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="@dimen/song_cover_size"
        android:layout_height="@dimen/song_cover_size"
        app:cardBackgroundColor="?attr/surfaceAltColor"
        app:cardCornerRadius="@dimen/song_cover_radius"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/ivCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note_24"
            app:tint="?attr/brandPrimary" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/textPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="?attr/textSecondary"
            android:textSize="12sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnDelete"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center_vertical"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/content_desc_remove"
        android:padding="12dp"
        android:src="@drawable/ic_delete_24"
        app:tint="?attr/dangerColor" />
</LinearLayout>
