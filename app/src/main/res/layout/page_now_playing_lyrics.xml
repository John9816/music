<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/lyricsPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingHorizontal="@dimen/spacing_m"
    android:paddingTop="@dimen/spacing_s"
    android:paddingBottom="@dimen/spacing_m">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCoverSmall"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <ImageView
            android:id="@+id/ivCoverSmall"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/current_playing_title"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note_24"
            android:tint="?attr/brandPrimary" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvTitleSmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_s"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:text="@string/current_playing_empty"
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.MusicPlayer.SectionTitle"
        android:textColor="?attr/textPrimary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvArtistSmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="@string/current_playing_hint"
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?attr/textSecondary" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/spacing_m">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLyrics"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never" />

        <TextView
            android:id="@+id/tvLyricsPlain"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_xl"
            android:text="@string/lyrics_not_available"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/textSecondary"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/pbLyrics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
