<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/cardDiscoverSearch"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_search_height"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/bg_toolbar_search_surface"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_s"
        android:paddingTop="0dp"
        android:paddingEnd="@dimen/spacing_s"
        android:paddingBottom="0dp">

        <FrameLayout
            android:layout_width="@dimen/toolbar_search_badge_size"
            android:layout_height="@dimen/toolbar_search_badge_size"
            android:background="@drawable/bg_toolbar_search_badge">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/action_search"
                android:src="@drawable/ic_search_24"
                android:tint="?attr/brandPrimaryDark" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/search_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/textPrimary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/nav_library"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/textSecondary" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="@dimen/toolbar_search_trailing_size"
            android:layout_height="@dimen/toolbar_search_trailing_size"
            android:background="@drawable/bg_toolbar_search_trailing">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:rotation="-90"
                android:src="@drawable/ic_chevron_down_24"
                android:tint="?attr/brandPrimary" />
        </FrameLayout>
    </LinearLayout>

</LinearLayout>

