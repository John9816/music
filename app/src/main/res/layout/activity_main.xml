<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/pageBackground">

    <include
        android:id="@+id/immersiveHeader"
        layout="@layout/include_immersive_header_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_toolbar_overlay_scrim"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            android:minHeight="@dimen/toolbar_min_height"
            android:paddingStart="@dimen/toolbar_content_padding_start"
            android:paddingEnd="@dimen/toolbar_content_padding_end"
            app:contentInsetStartWithNavigation="0dp"
            app:itemIconTint="?attr/colorOnSurfaceVariant"
            app:navigationIconTint="?attr/colorOnSurfaceVariant"
            app:subtitleTextColor="?attr/colorOnSurfaceVariant"
            app:titleTextColor="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="?attr/pageBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/bottomContentBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierAllowsGoneWidgets="true"
        app:barrierDirection="top"
        app:constraint_referenced_ids="miniPlayer,bottomNavContainer" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/miniPlayer"
        style="@style/Widget.MusicPlayer.Card.Outlined"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="6dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/ripple_rect_primary"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/glassSurfaceStrong"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="?attr/glassStrokeSoft"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/mini_player_height">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/coverContainer"
                android:layout_width="@dimen/mini_player_cover_size"
                android:layout_height="@dimen/mini_player_cover_size"
                android:layout_marginStart="8dp"
                app:cardBackgroundColor="?attr/surfaceAltColor"
                app:cardCornerRadius="9dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeColor="@android:color/transparent"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/ivMiniCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/current_playing_title"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_music_note_24"
                    app:tint="?attr/brandPrimary" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvMiniTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="8dp"
                android:ellipsize="marquee"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:marqueeRepeatLimit="marquee_forever"
                android:maxLines="1"
                android:scrollHorizontally="true"
                android:singleLine="true"
                android:text="@string/current_playing_empty"
                android:textColor="?attr/textPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/tvMiniArtist"
                app:layout_constraintEnd_toStartOf="@id/miniPlayPauseContainer"
                app:layout_constraintStart_toEndOf="@id/coverContainer"
                app:layout_constraintTop_toTopOf="@id/coverContainer"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tvMiniArtist"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/current_playing_hint"
                android:textColor="?attr/textSecondary"
                android:textSize="11sp"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="@id/coverContainer"
                app:layout_constraintEnd_toStartOf="@id/miniPlayPauseContainer"
                app:layout_constraintStart_toEndOf="@id/coverContainer"
                app:layout_constraintTop_toBottomOf="@id/tvMiniTitle" />

            <FrameLayout
                android:id="@+id/miniPlayPauseContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="2dp"
                app:layout_constraintBottom_toBottomOf="@id/coverContainer"
                app:layout_constraintEnd_toStartOf="@id/btnMiniQueue"
                app:layout_constraintTop_toTopOf="@id/coverContainer">

                <ImageButton
                    android:id="@+id/btnMiniPlayPause"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/content_desc_play_pause"
                    android:padding="8dp"
                    android:src="@drawable/ic_pause_24"
                    app:tint="?attr/textPrimary" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/btnMiniQueue"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_next"
                android:padding="8dp"
                android:src="@drawable/ic_skip_next_24"
                app:layout_constraintBottom_toBottomOf="@id/coverContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/coverContainer"
                app:tint="?attr/textSecondary" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/miniProgress"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:clickable="false"
                android:focusable="false"
                android:indeterminate="false"
                android:importantForAccessibility="no"
                app:indicatorColor="?attr/brandPrimary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:trackColor="?attr/dividerColor"
                app:trackThickness="2dp"
                app:trackCornerRadius="0dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_nav_minimal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Custom bottom bar: avoids Material dual-label scale glitches on first paint. -->
        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_content_height"
            android:background="@android:color/transparent"
            android:baselineAligned="false"
            android:gravity="center"
            android:minHeight="@dimen/bottom_nav_content_height"
            android:orientation="horizontal"
            android:paddingHorizontal="0dp">

            <include
                android:id="@+id/nav_discover"
                layout="@layout/item_bottom_nav_tab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <include
                android:id="@+id/nav_playlists"
                layout="@layout/item_bottom_nav_tab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <include
                android:id="@+id/nav_library"
                layout="@layout/item_bottom_nav_tab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <include
                android:id="@+id/nav_profile"
                layout="@layout/item_bottom_nav_tab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />
        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
