<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <include
        android:id="@+id/immersiveHeader"
        layout="@layout/include_immersive_header_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_toolbar_overlay_scrim"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            android:minHeight="@dimen/toolbar_min_height"
            android:paddingStart="@dimen/toolbar_content_padding_start"
            android:paddingEnd="@dimen/toolbar_content_padding_end"
            app:contentInsetStartWithNavigation="0dp"
            app:itemIconTint="?attr/colorOnSurfaceVariant"
            app:navigationIconTint="?attr/colorOnSurfaceVariant"
            app:subtitleTextColor="?attr/colorOnSurfaceVariant"
            app:titleTextColor="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/bottomContentBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierAllowsGoneWidgets="true"
        app:barrierDirection="top"
        app:constraint_referenced_ids="miniPlayer,bottomNavContainer" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/miniPlayer"
        style="@style/Widget.MusicPlayer.Card.Outlined"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_m"
        android:layout_marginTop="@dimen/spacing_s"
        android:layout_marginEnd="@dimen/spacing_m"
        android:layout_marginBottom="@dimen/spacing_s"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/surfaceColor"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="?attr/dividerColor"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingTop="@dimen/spacing_s"
            android:paddingEnd="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_s">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/coverContainer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardBackgroundColor="?attr/surfaceColor"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/dividerColor"
                app:strokeWidth="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivMiniCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/current_playing_title"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_music_note_24"
                    app:tint="?attr/brandPrimary" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvMiniTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_m"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/current_playing_empty"
                android:textAppearance="@style/TextAppearance.MusicPlayer.SectionTitle"
                android:textColor="?attr/textPrimary"
                app:layout_constraintEnd_toStartOf="@id/miniPlayPauseContainer"
                app:layout_constraintStart_toEndOf="@id/coverContainer"
                app:layout_constraintBottom_toBottomOf="@id/coverContainer"
                app:layout_constraintTop_toTopOf="@id/coverContainer" />

            <FrameLayout
                android:id="@+id/miniPlayPauseContainer"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:layout_constraintBottom_toBottomOf="@id/coverContainer"
                android:layout_marginEnd="@dimen/spacing_xs"
                app:layout_constraintEnd_toStartOf="@id/btnMiniQueue"
                app:layout_constraintTop_toTopOf="@id/coverContainer">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/miniProgress"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clickable="false"
                    android:focusable="false"
                    android:indeterminate="false"
                    android:importantForAccessibility="no"
                    app:indicatorColor="?attr/brandPrimary"
                    app:indicatorInset="0dp"
                    app:indicatorSize="36dp"
                    app:trackColor="?attr/colorOutline"
                    app:trackThickness="2dp" />

                <ImageButton
                    android:id="@+id/btnMiniPlayPause"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/content_desc_play_pause"
                    android:padding="6dp"
                    android:src="@drawable/ic_pause_24"
                    app:tint="?attr/textPrimary" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/btnMiniQueue"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_queue"
                android:padding="6dp"
                android:src="@drawable/ic_queue_24"
                app:tint="?attr/textPrimary"
                app:layout_constraintBottom_toBottomOf="@id/coverContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/coverContainer" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            style="@style/Widget.Material3.BottomNavigationView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_m"
            android:layout_marginEnd="@dimen/spacing_m"
            android:layout_marginBottom="@dimen/spacing_s"
            android:layout_marginTop="@dimen/spacing_xs"
            android:background="@drawable/bg_floating_nav"
            android:elevation="0dp"
            android:paddingHorizontal="@dimen/spacing_m"
            android:paddingTop="@dimen/spacing_xs"
            android:paddingBottom="@dimen/spacing_xs"
            app:labelVisibilityMode="labeled"
            app:itemIconTint="@color/navigation_item_color"
            app:itemTextColor="@color/navigation_item_color"
            app:menu="@menu/bottom_nav" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
