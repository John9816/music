<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/pageBackground">

    <include
        android:id="@+id/immersiveHeader"
        layout="@layout/include_immersive_header_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_toolbar_overlay_scrim"
        android:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            android:minHeight="@dimen/toolbar_min_height"
            android:paddingStart="@dimen/toolbar_content_padding_start"
            android:paddingEnd="@dimen/toolbar_content_padding_end"
            app:contentInsetStartWithNavigation="0dp"
            app:itemIconTint="?attr/colorOnSurfaceVariant"
            app:navigationIconTint="?attr/colorOnSurfaceVariant"
            app:subtitleTextColor="?attr/colorOnSurfaceVariant"
            app:titleTextColor="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="?attr/pageBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/bottomContentBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierAllowsGoneWidgets="true"
        app:barrierDirection="top"
        app:constraint_referenced_ids="miniPlayer,bottomNavContainer" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/miniPlayer"
        style="@style/Widget.MusicPlayer.Card.Outlined"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/ripple_rect_primary"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/surfaceColor"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:cardCornerRadius="12dp"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="60dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/coverContainer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="?attr/surfaceColor"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/dividerColor"
                app:strokeWidth="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivMiniCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/current_playing_title"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_music_note_24"
                    app:tint="?attr/brandPrimary" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvMiniTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="16dp"
                android:ellipsize="marquee"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:marqueeRepeatLimit="marquee_forever"
                android:scrollHorizontally="true"
                android:singleLine="true"
                android:text="@string/current_playing_empty"
                android:textColor="?attr/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/coverContainer"
                app:layout_constraintEnd_toStartOf="@id/miniPlayPauseContainer"
                app:layout_constraintStart_toEndOf="@id/coverContainer"
                app:layout_constraintTop_toTopOf="@id/coverContainer" />

            <TextView
                android:id="@+id/tvMiniArtist"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_m"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/current_playing_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/textSecondary"
                android:visibility="gone"
                app:layout_constraintEnd_toStartOf="@id/miniPlayPauseContainer"
                app:layout_constraintStart_toEndOf="@id/coverContainer"
                app:layout_constraintTop_toBottomOf="@id/tvMiniTitle" />

            <FrameLayout
                android:id="@+id/miniPlayPauseContainer"
                android:layout_width="32dp"
                android:layout_height="40dp"
                app:layout_constraintBottom_toBottomOf="@id/coverContainer"
                android:layout_marginEnd="12dp"
                app:layout_constraintEnd_toStartOf="@id/btnMiniQueue"
                app:layout_constraintTop_toTopOf="@id/coverContainer">

                <ImageButton
                    android:id="@+id/btnMiniPlayPause"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/content_desc_play_pause"
                    android:padding="4dp"
                    android:src="@drawable/ic_pause_24"
                    app:tint="?attr/textPrimary" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/btnMiniQueue"
                android:layout_width="32dp"
                android:layout_height="40dp"
                android:layout_marginEnd="16dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/content_desc_next"
                android:padding="5dp"
                android:src="@drawable/ic_skip_next_24"
                app:tint="?attr/textPrimary"
                app:layout_constraintBottom_toBottomOf="@id/coverContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/coverContainer" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/miniProgress"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:clickable="false"
                android:focusable="false"
                android:indeterminate="false"
                android:importantForAccessibility="no"
                app:indicatorColor="?attr/brandPrimary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:trackColor="?attr/colorOutline"
                app:trackThickness="2dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_nav_minimal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            style="@style/Widget.Material3.BottomNavigationView"
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_content_height"
            android:layout_marginStart="0dp"
            android:layout_marginTop="0dp"
            android:layout_marginEnd="0dp"
            android:layout_marginBottom="0dp"
            android:background="@android:color/transparent"
            android:elevation="0dp"
            android:minHeight="@dimen/bottom_nav_content_height"
            android:paddingHorizontal="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            app:itemIconSize="24dp"
            app:itemPaddingBottom="0dp"
            app:itemPaddingTop="0dp"
            app:itemTextAppearanceActive="@style/TextAppearance.MusicPlayer.BottomNav"
            app:itemTextAppearanceInactive="@style/TextAppearance.MusicPlayer.BottomNav"
            app:labelVisibilityMode="labeled"
            app:itemIconTint="@color/navigation_item_color"
            app:itemTextColor="@color/navigation_item_color"
            app:menu="@menu/bottom_nav" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
