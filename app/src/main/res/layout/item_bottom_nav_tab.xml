<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:background="@drawable/ripple_rect_primary"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingTop="@dimen/bottom_nav_item_padding_top"
    android:paddingBottom="@dimen/bottom_nav_item_padding_bottom">

    <ImageView
        android:id="@+id/ivTabIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        tools:src="@drawable/ic_music_note_24"
        tools:tint="?attr/textSecondary" />

    <TextView
        android:id="@+id/tvTabLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/bottom_nav_icon_label_gap"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textAppearance="@style/TextAppearance.MusicPlayer.BottomNav"
        android:textSize="@dimen/bottom_nav_label_text_size"
        tools:text="歌曲"
        tools:textColor="?attr/textSecondary" />
</LinearLayout>
