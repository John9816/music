<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="@dimen/spacing_m"
    android:paddingTop="@dimen/spacing_s"
    android:paddingEnd="@dimen/spacing_m"
    android:paddingBottom="@dimen/spacing_s">

    <FrameLayout
        android:id="@+id/stageContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/tvTitleBig"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/coverStage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/discContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:id="@+id/viewDiscRim"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/bg_disc_rim"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCoverBig"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:cardBackgroundColor="?attr/surfaceColor"
                    app:cardCornerRadius="200dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintBottom_toBottomOf="@id/viewDiscRim"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="@id/viewDiscRim"
                    app:layout_constraintStart_toStartOf="@id/viewDiscRim"
                    app:layout_constraintTop_toTopOf="@id/viewDiscRim"
                    android:layout_margin="18dp">

                    <ImageView
                        android:id="@+id/ivCoverBig"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/current_playing_title"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_music_note_24"
                        app:tint="?attr/brandPrimary" />
                </com.google.android.material.card.MaterialCardView>

                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@drawable/bg_disc_center"
                    app:layout_constraintBottom_toBottomOf="@id/viewDiscRim"
                    app:layout_constraintEnd_toEndOf="@id/viewDiscRim"
                    app:layout_constraintStart_toStartOf="@id/viewDiscRim"
                    app:layout_constraintTop_toTopOf="@id/viewDiscRim" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/lyricsStage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_l"
                android:paddingTop="@dimen/spacing_m"
                android:paddingEnd="@dimen/spacing_l"
                android:paddingBottom="@dimen/spacing_m">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvLyrics"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:overScrollMode="never" />

                    <TextView
                        android:id="@+id/tvLyricsPlain"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/spacing_xl"
                        android:text="@string/lyrics_not_available"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/textSecondary"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/tvTitleBig"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_xs"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:text="@string/current_playing_empty"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
        android:textColor="?attr/textPrimary"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tvArtistBig"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvArtistBig"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="@string/current_playing_hint"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        android:textColor="?attr/textSecondary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
