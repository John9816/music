<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingStart="@dimen/spacing_m"
    android:paddingTop="@dimen/spacing_s"
    android:paddingEnd="@dimen/spacing_m"
    android:paddingBottom="@dimen/spacing_m">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCoverBig"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/ivCoverBig"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/current_playing_title"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note_24"
                android:tint="?attr/brandPrimary" />
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <TextView
        android:id="@+id/tvTitleBig"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_l"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="@string/current_playing_empty"
        android:textAppearance="@style/TextAppearance.MusicPlayer.SectionTitle"
        android:textColor="?attr/textPrimary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvArtistBig"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/current_playing_hint"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?attr/textSecondary" />

</LinearLayout>
