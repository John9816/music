<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="@dimen/spacing_m"
        android:paddingTop="@dimen/spacing_l"
        android:paddingEnd="@dimen/spacing_m"
        android:paddingBottom="@dimen/spacing_m"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvHeaderEyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_profile"
            android:textAppearance="@style/TextAppearance.MusicPlayer.Eyebrow"
            android:textColor="?attr/brandPrimary"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/headerCoverContainer"
            android:layout_width="84dp"
            android:layout_height="84dp"
            app:cardBackgroundColor="?attr/surfaceColor"
            app:cardCornerRadius="@dimen/radius_xl"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="?attr/dividerColor"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ivHeaderCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/current_playing_title"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_music_note_24"
                    android:tint="?attr/brandPrimary" />

                <TextView
                    android:id="@+id/tvHeaderPlayCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="6dp"
                    android:background="@drawable/bg_play_count_badge"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingStart="6dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="6dp"
                    android:paddingBottom="2dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivHeaderOverlay"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_toolbar_action_button"
                    android:contentDescription="@string/action_favorite"
                    android:padding="6dp"
                    android:src="@drawable/ic_favorite_24"
                    android:tint="?attr/textPrimary" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_s"
            android:layout_marginEnd="@dimen/spacing_l"
            android:ellipsize="end"
            android:maxLines="3"
            android:text="@string/profile_liked_title"
            android:textAppearance="@style/TextAppearance.MusicPlayer.SectionTitle"
            android:textColor="?attr/textPrimary"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/headerCoverContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHeaderEyebrow" />

        <TextView
            android:id="@+id/tvHeaderDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_s"
            android:layout_marginEnd="@dimen/spacing_l"
            android:ellipsize="end"
            android:maxLines="3"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/textSecondary"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@id/headerCoverContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/headerBottomBarrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="headerCoverContainer,tvHeaderEyebrow,tvHeaderTitle,tvHeaderDescription" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlayAll"
            style="@style/Widget.MusicPlayer.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_l"
            android:minWidth="0dp"
            android:text="@string/action_play_all"
            android:textColor="?attr/textPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="@dimen/radius_2xl"
            app:icon="@drawable/ic_play_24"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="?attr/textPrimary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerBottomBarrier"
            app:layout_goneMarginTop="@dimen/spacing_l"
            app:strokeColor="?attr/dividerColor"
            app:strokeWidth="1dp" />

        <View
            android:id="@+id/headerDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/spacing_l"
            android:alpha="0.4"
            android:background="?attr/colorOutline"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnPlayAll" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_xl"
            android:text="@string/profile_liked_empty"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/textSecondary"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerDivider" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_m"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="@dimen/spacing_xxl"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerDivider" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
