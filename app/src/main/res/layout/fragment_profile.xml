<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/pageBackground">

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_3xl">

            <!-- Top bar: title + settings -->
            <LinearLayout
                android:id="@+id/layoutHeroContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_m"
                android:paddingTop="@dimen/spacing_s"
                android:paddingEnd="@dimen/spacing_s"
                android:paddingBottom="@dimen/spacing_s">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/nav_profile"
                    android:textAppearance="@style/TextAppearance.MusicPlayer.HeroTitle"
                    android:textColor="?attr/textPrimary"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/content_desc_settings"
                    android:padding="12dp"
                    android:src="@drawable/ic_settings_24"
                    app:tint="?attr/textPrimary" />
            </LinearLayout>

            <!-- User header (NetEase style: avatar left, name + meta) -->
            <LinearLayout
                android:id="@+id/layoutUserHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/ripple_rect_primary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_m"
                android:paddingTop="@dimen/spacing_s"
                android:paddingEnd="@dimen/spacing_m"
                android:paddingBottom="@dimen/spacing_m">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/profile_avatar_size"
                    android:layout_height="@dimen/profile_avatar_size"
                    app:cardBackgroundColor="?attr/brandPrimaryLight"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/glassStrokeSoft"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/content_desc_avatar"
                        android:padding="16dp"
                        android:scaleType="center"
                        android:src="@drawable/ic_person_24"
                        app:tint="?attr/brandPrimary" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_m"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvNickname"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/profile_nickname_placeholder"
                            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                            android:textColor="?attr/textPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_s"
                            android:background="@drawable/bg_profile_badge_chip"
                            android:paddingHorizontal="@dimen/spacing_s"
                            android:paddingVertical="@dimen/spacing_xs"
                            android:textColor="?attr/brandPrimary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvProfileMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/profile_account_placeholder"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/textSecondary" />

                    <TextView
                        android:id="@+id/tvSignature"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/profile_signature_empty"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/textSecondary" />
                </LinearLayout>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:importantForAccessibility="no"
                    android:rotation="-90"
                    android:src="@drawable/ic_chevron_down_24"
                    app:tint="?attr/textSecondary" />
            </LinearLayout>

            <!-- Quick grid: 喜欢 / 最近 / 下载 / 歌单 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/spacing_m"
                android:paddingTop="@dimen/spacing_s"
                android:text="@string/profile_quick_section"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/textPrimary"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutQuickGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_s"
                android:weightSum="4">

                <LinearLayout
                    android:id="@+id/gridLiked"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/ripple_rect_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <FrameLayout
                        android:layout_width="@dimen/profile_grid_icon_size"
                        android:layout_height="@dimen/profile_grid_icon_size"
                        android:background="@drawable/bg_profile_grid_icon">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_favorite_24"
                            app:tint="?attr/brandPrimary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_s"
                        android:text="@string/profile_stat_liked"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/textPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvGridLikedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="0"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/textSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/gridHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/ripple_rect_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <FrameLayout
                        android:layout_width="@dimen/profile_grid_icon_size"
                        android:layout_height="@dimen/profile_grid_icon_size"
                        android:background="@drawable/bg_profile_grid_icon">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_history_24"
                            app:tint="?attr/brandPrimary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_s"
                        android:text="@string/profile_stat_history"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/textPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvGridHistoryCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="0"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/textSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/gridDownloads"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/ripple_rect_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <FrameLayout
                        android:layout_width="@dimen/profile_grid_icon_size"
                        android:layout_height="@dimen/profile_grid_icon_size"
                        android:background="@drawable/bg_profile_grid_icon">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_download_24"
                            app:tint="?attr/brandPrimary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_s"
                        android:text="@string/profile_stat_downloads"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/textPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvGridDownloadsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="0"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/textSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/gridPlaylists"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/ripple_rect_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <FrameLayout
                        android:layout_width="@dimen/profile_grid_icon_size"
                        android:layout_height="@dimen/profile_grid_icon_size"
                        android:background="@drawable/bg_profile_grid_icon">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_playlist_24"
                            app:tint="?attr/brandPrimary" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_s"
                        android:text="@string/profile_stat_playlists"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/textPrimary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvGridPlaylistsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="0"
                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/textSecondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- 我喜欢的音乐：固定红色渐变（不依赖 theme attr，避免白底白字） -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLiked"
                android:layout_width="match_parent"
                android:layout_height="@dimen/profile_liked_card_height"
                android:layout_marginHorizontal="@dimen/spacing_m"
                android:layout_marginTop="@dimen/spacing_l"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/cymusic_red"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="0dp"
                app:rippleColor="#40FFFFFF"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_profile_liked_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/spacing_m">

                        <FrameLayout
                            android:layout_width="@dimen/profile_liked_cover_size"
                            android:layout_height="@dimen/profile_liked_cover_size"
                            android:background="@drawable/bg_profile_liked_cover">

                            <ImageView
                                android:id="@+id/ivLikedCover"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/favorites_title"
                                android:padding="@dimen/profile_cover_placeholder_padding"
                                android:scaleType="center"
                                android:src="@drawable/ic_favorite_24"
                                app:tint="@color/white" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_m"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvLikedTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/profile_liked_title"
                                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                android:textColor="@color/white"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvLikedMeta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_xs"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/profile_liked_empty"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="#E6FFFFFF" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_profile_liked_play"
                            android:contentDescription="@string/action_play_all"
                            android:padding="8dp"
                            android:src="@drawable/ic_play_24"
                            app:tint="@color/cymusic_red" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Library list: history / downloads / playlists -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:paddingHorizontal="@dimen/spacing_m"
                android:text="@string/profile_library_section"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/textPrimary"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_m"
                android:layout_marginTop="@dimen/spacing_m"
                android:background="@drawable/bg_cymusic_group"
                android:divider="@drawable/divider_settings"
                android:orientation="vertical"
                android:showDividers="middle">

                <LinearLayout
                    android:id="@+id/rowHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ripple_rect_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_m"
                    android:paddingVertical="@dimen/spacing_sm">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/profile_cover_size"
                        android:layout_height="@dimen/profile_cover_size"
                        app:cardBackgroundColor="?attr/surfaceAltColor"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivHistoryCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/history_title"
                            android:padding="@dimen/profile_cover_placeholder_padding"
                            android:scaleType="center"
                            android:src="@drawable/ic_history_24"
                            app:tint="?attr/brandPrimary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvHistoryTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/profile_history_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/textPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvHistoryMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/profile_history_empty"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/textSecondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:importantForAccessibility="no"
                        android:rotation="-90"
                        android:src="@drawable/ic_chevron_down_24"
                        app:tint="?attr/textSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowDownloads"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ripple_rect_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_m"
                    android:paddingVertical="@dimen/spacing_sm">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/profile_cover_size"
                        android:layout_height="@dimen/profile_cover_size"
                        app:cardBackgroundColor="?attr/surfaceAltColor"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivDownloadsCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/downloads_title"
                            android:padding="@dimen/profile_cover_placeholder_padding"
                            android:scaleType="center"
                            android:src="@drawable/ic_download_24"
                            app:tint="?attr/brandPrimary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDownloadsTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/profile_downloads_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/textPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDownloadsMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/profile_downloads_empty"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/textSecondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:importantForAccessibility="no"
                        android:rotation="-90"
                        android:src="@drawable/ic_chevron_down_24"
                        app:tint="?attr/textSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowPlaylists"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ripple_rect_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_m"
                    android:paddingVertical="@dimen/spacing_sm">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/profile_cover_size"
                        android:layout_height="@dimen/profile_cover_size"
                        app:cardBackgroundColor="?attr/surfaceAltColor"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivPlaylistCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/user_playlist_title"
                            android:padding="@dimen/profile_cover_placeholder_padding"
                            android:scaleType="center"
                            android:src="@drawable/ic_playlist_24"
                            app:tint="?attr/brandPrimary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvPlaylistsTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/user_playlist_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/textPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvPlaylistsMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/user_playlist_empty"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/textSecondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:importantForAccessibility="no"
                        android:rotation="-90"
                        android:src="@drawable/ic_chevron_down_24"
                        app:tint="?attr/textSecondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Hidden counters kept for binding compatibility -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvSyncHint"
                    android:layout_width="1dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/tvLikedCount"
                    android:layout_width="1dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/tvHistoryCount"
                    android:layout_width="1dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/tvPlaylistCount"
                    android:layout_width="1dp"
                    android:layout_height="1dp" />

                <!-- Legacy rowLiked id alias: cardLiked is the main entry; keep row for safety -->
                <View
                    android:id="@+id/rowLiked"
                    android:layout_width="1dp"
                    android:layout_height="1dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/stickyProfileTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/pageBackground"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_m"
        android:paddingTop="@dimen/spacing_s"
        android:paddingEnd="@dimen/spacing_s"
        android:paddingBottom="@dimen/spacing_s"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nav_profile"
            android:textAppearance="@style/TextAppearance.MusicPlayer.HeroTitle"
            android:textColor="?attr/textPrimary"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnSettingsSticky"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_settings"
            android:padding="12dp"
            android:src="@drawable/ic_settings_24"
            app:tint="?attr/textPrimary" />
    </LinearLayout>
</FrameLayout>
