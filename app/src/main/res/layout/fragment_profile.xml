<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:id="@+id/scrollContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_m"
                android:paddingTop="@dimen/spacing_l"
                android:paddingEnd="@dimen/spacing_m"
                android:paddingBottom="@dimen/spacing_3xl">

                <LinearLayout
                    android:id="@+id/layoutHeroContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/nav_favorites"
                        android:textAppearance="@style/TextAppearance.MusicPlayer.HeroTitle"
                        android:textColor="?attr/textPrimary"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btnSettings"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/content_desc_settings"
                        android:padding="12dp"
                        android:src="@drawable/ic_settings_24"
                        app:tint="?attr/textPrimary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/toolbar_search_height"
                    android:layout_marginTop="@dimen/spacing_s"
                    android:background="@drawable/bg_toolbar_search_surface"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/spacing_s"
                    android:paddingEnd="@dimen/spacing_s">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@string/action_search"
                        android:src="@drawable/ic_search_24"
                        app:tint="?attr/textSecondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_s"
                        android:layout_weight="1"
                        android:text="Find in favorites"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="?attr/textSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rowLiked"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_m"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/spacing_s"
                    android:paddingBottom="@dimen/spacing_s">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardBackgroundColor="?attr/surfaceAltColor"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/dividerColor"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:id="@+id/ivLikedCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/favorites_title"
                            android:padding="18dp"
                            android:scaleType="center"
                            android:src="@drawable/ic_favorite_24"
                            app:tint="?attr/brandPrimary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvLikedTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/profile_liked_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/textPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvLikedMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/profile_liked_empty"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/textSecondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:rotation="-90"
                        android:src="@drawable/ic_chevron_down_24"
                        app:tint="?attr/textSecondary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="80dp"
                    android:background="?attr/colorOutline" />

                <LinearLayout
                    android:id="@+id/rowHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/spacing_s"
                    android:paddingBottom="@dimen/spacing_s">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardBackgroundColor="?attr/surfaceAltColor"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/dividerColor"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:id="@+id/ivHistoryCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/history_title"
                            android:padding="18dp"
                            android:scaleType="center"
                            android:src="@drawable/ic_history_24"
                            app:tint="?attr/brandPrimary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvHistoryTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="有人说：要感谢前任让..."
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/textPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvHistoryMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text=""
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/textSecondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:rotation="-90"
                        android:src="@drawable/ic_chevron_down_24"
                        app:tint="?attr/textSecondary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="80dp"
                    android:background="?attr/colorOutline" />

                <LinearLayout
                    android:id="@+id/rowPlaylists"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/spacing_s"
                    android:paddingBottom="@dimen/spacing_s">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardBackgroundColor="?attr/surfaceAltColor"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?attr/dividerColor"
                        app:strokeWidth="1dp">

                        <ImageView
                            android:id="@+id/ivPlaylistCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/user_playlist_title"
                            android:padding="18dp"
                            android:scaleType="center"
                            android:src="@drawable/ic_playlist_24"
                            app:tint="?attr/brandPrimary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvPlaylistsTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="伍佰 &amp; ChinaBlue，伍..."
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/textPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvPlaylistsMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/user_playlist_empty"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/textSecondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:rotation="-90"
                        android:src="@drawable/ic_chevron_down_24"
                        app:tint="?attr/textSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="1dp"
                        android:layout_height="1dp"
                        android:contentDescription="@string/content_desc_avatar" />
                    <TextView
                        android:id="@+id/tvNickname"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/tvSignature"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/tvBadge"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/tvProfileMeta"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/tvSyncHint"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/tvLikedCount"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/tvHistoryCount"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/tvPlaylistCount"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</FrameLayout>
