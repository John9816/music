<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/pageBackground">

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_m"
                android:paddingTop="@dimen/spacing_s"
                android:paddingEnd="@dimen/spacing_m"
                android:paddingBottom="@dimen/spacing_3xl">

                <LinearLayout
                    android:id="@+id/layoutHeroContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/pageBackground"
                    android:elevation="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/nav_profile"
                        android:textAppearance="@style/TextAppearance.MusicPlayer.HeroTitle"
                        android:textColor="?attr/textPrimary"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btnSettings"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/content_desc_settings"
                        android:padding="12dp"
                        android:src="@drawable/ic_settings_24"
                        app:tint="?attr/textPrimary" />

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.MusicPlayer.Card.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_l">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_m">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            app:cardBackgroundColor="?attr/brandPrimaryLight"
                            app:cardCornerRadius="36dp"
                            app:cardElevation="0dp"
                            app:strokeColor="?attr/glassStrokeSoft"
                            app:strokeWidth="1dp">

                            <ImageView
                                android:id="@+id/ivAvatar"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/content_desc_avatar"
                                android:padding="18dp"
                                android:scaleType="center"
                                android:src="@drawable/ic_person_24"
                                app:tint="?attr/brandPrimary" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_m"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tvNickname"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="@string/profile_nickname_placeholder"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                    android:textColor="?attr/textPrimary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvBadge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/spacing_s"
                                    android:background="?attr/brandPrimaryLight"
                                    android:paddingHorizontal="@dimen/spacing_s"
                                    android:paddingVertical="@dimen/spacing_xs"
                                    android:textColor="?attr/brandPrimary"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:visibility="gone" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvProfileMeta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_xs"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/profile_account_placeholder"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="?attr/textSecondary" />

                            <TextView
                                android:id="@+id/tvSignature"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_xs"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="@string/profile_signature_empty"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="?attr/textSecondary" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_l"
                    android:text="@string/profile_library_section"
                    android:textAppearance="@style/TextAppearance.MusicPlayer.Eyebrow"
                    android:textColor="?attr/textSecondary"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/rowLiked"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_m"
                    android:background="@drawable/ripple_rect_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/spacing_s"
                    android:paddingBottom="@dimen/spacing_s">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/profile_cover_size"
                        android:layout_height="@dimen/profile_cover_size"
                        app:cardBackgroundColor="?attr/surfaceAltColor"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivLikedCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/favorites_title"
                            android:padding="@dimen/profile_cover_placeholder_padding"
                            android:scaleType="center"
                            android:src="@drawable/ic_favorite_24"
                            app:tint="?attr/brandPrimary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvLikedTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/profile_liked_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/textPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvLikedMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/profile_liked_empty"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/textSecondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:importantForAccessibility="no"
                        android:rotation="-90"
                        android:src="@drawable/ic_chevron_down_24"
                        app:tint="?attr/textSecondary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="80dp"
                    android:background="?attr/colorOutline" />

                <LinearLayout
                    android:id="@+id/rowHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ripple_rect_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/spacing_s"
                    android:paddingBottom="@dimen/spacing_s">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/profile_cover_size"
                        android:layout_height="@dimen/profile_cover_size"
                        app:cardBackgroundColor="?attr/surfaceAltColor"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivHistoryCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/history_title"
                            android:padding="@dimen/profile_cover_placeholder_padding"
                            android:scaleType="center"
                            android:src="@drawable/ic_history_24"
                            app:tint="?attr/brandPrimary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvHistoryTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/profile_history_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/textPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvHistoryMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text=""
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/textSecondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:importantForAccessibility="no"
                        android:rotation="-90"
                        android:src="@drawable/ic_chevron_down_24"
                        app:tint="?attr/textSecondary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="80dp"
                    android:background="?attr/colorOutline" />

                <LinearLayout
                    android:id="@+id/rowPlaylists"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/ripple_rect_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/spacing_s"
                    android:paddingBottom="@dimen/spacing_s">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="@dimen/profile_cover_size"
                        android:layout_height="@dimen/profile_cover_size"
                        app:cardBackgroundColor="?attr/surfaceAltColor"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivPlaylistCover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/user_playlist_title"
                            android:padding="@dimen/profile_cover_placeholder_padding"
                            android:scaleType="center"
                            android:src="@drawable/ic_playlist_24"
                            app:tint="?attr/brandPrimary" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvPlaylistsTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/user_playlist_title"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="?attr/textPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvPlaylistsMeta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/user_playlist_empty"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/textSecondary" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:importantForAccessibility="no"
                        android:rotation="-90"
                        android:src="@drawable/ic_chevron_down_24"
                        app:tint="?attr/textSecondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvSyncHint"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/tvLikedCount"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/tvHistoryCount"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                    <TextView
                        android:id="@+id/tvPlaylistCount"
                        android:layout_width="1dp"
                        android:layout_height="1dp" />
                </LinearLayout>
            </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/stickyProfileTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/pageBackground"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_m"
        android:paddingTop="@dimen/spacing_s"
        android:paddingEnd="@dimen/spacing_m"
        android:paddingBottom="@dimen/spacing_s"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nav_profile"
            android:textAppearance="@style/TextAppearance.MusicPlayer.HeroTitle"
            android:textColor="?attr/textPrimary"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnSettingsSticky"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_settings"
            android:padding="12dp"
            android:src="@drawable/ic_settings_24"
            app:tint="?attr/textPrimary" />
    </LinearLayout>
</FrameLayout>
