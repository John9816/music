<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:id="@+id/scrollContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_m"
                android:paddingTop="@dimen/spacing_l"
                android:paddingEnd="@dimen/spacing_m"
                android:paddingBottom="@dimen/spacing_3xl">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.MusicPlayer.Card.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="280dp"
                            android:contentDescription="@string/profile_title"
                            android:scaleType="centerCrop"
                            android:src="@drawable/bg_header_default" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:alpha="0.60"
                            android:background="@drawable/bg_header_top_scrim" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="@dimen/spacing_l"
                            android:paddingTop="@dimen/spacing_l"
                            android:paddingEnd="@dimen/spacing_l"
                            android:paddingBottom="@dimen/spacing_l">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/nav_profile"
                                        android:textAppearance="@style/TextAppearance.MusicPlayer.Eyebrow"
                                        android:textColor="?attr/brandPrimary"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/spacing_s"
                                        android:text="@string/profile_overview_label"
                                        android:textAppearance="@style/TextAppearance.MusicPlayer.SectionTitle"
                                        android:textColor="?attr/textPrimary"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <ImageButton
                                    android:id="@+id/btnSettings"
                                    android:layout_width="@dimen/toolbar_action_size"
                                    android:layout_height="@dimen/toolbar_action_size"
                                    android:background="@drawable/bg_toolbar_action_button"
                                    android:contentDescription="@string/content_desc_settings"
                                    android:padding="@dimen/spacing_s"
                                    android:src="@drawable/ic_settings_24"
                                    android:tint="?attr/textPrimary" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_l"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:id="@+id/ivAvatar"
                                    android:layout_width="92dp"
                                    android:layout_height="92dp"
                                    android:background="@drawable/bg_glass_button_circle"
                                    android:contentDescription="@string/content_desc_avatar"
                                    android:padding="22dp"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/ic_person_24"
                                    android:tint="?attr/brandPrimary" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/spacing_m"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvNickname"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/profile_nickname_placeholder"
                                        android:textAppearance="@style/TextAppearance.MusicPlayer.SectionTitle"
                                        android:textColor="?attr/textPrimary"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvSignature"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/spacing_s"
                                        android:maxLines="2"
                                        android:text="@string/profile_signature_empty"
                                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                        android:textColor="?attr/textSecondary" />

                                    <TextView
                                        android:id="@+id/tvBadge"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/spacing_sm"
                                        android:paddingVertical="2dp"
                                        android:textColor="?attr/brandPrimary"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:visibility="gone" />

                                    <TextView
                                        android:id="@+id/tvProfileMeta"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/spacing_sm"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/profile_account_placeholder"
                                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                        android:textColor="?attr/textSecondary" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_l"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1.15"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvLikedCount"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0"
                                        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                                        android:textColor="?attr/textPrimary"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/spacing_xs"
                                        android:text="@string/profile_stat_liked"
                                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                        android:textColor="?attr/textSecondary" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/spacing_m"
                                        android:text="@string/profile_liked_hint"
                                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                        android:textColor="?attr/textSecondary" />
                                </LinearLayout>

                                <Space
                                    android:layout_width="@dimen/spacing_s"
                                    android:layout_height="1dp" />

                                <View
                                    android:layout_width="1dp"
                                    android:layout_height="match_parent"
                                    android:background="?attr/colorOutline" />

                                <Space
                                    android:layout_width="@dimen/spacing_s"
                                    android:layout_height="1dp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="0.85"
                                    android:orientation="vertical">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical">

                                        <TextView
                                            android:id="@+id/tvHistoryCount"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0"
                                            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                                            android:textColor="?attr/textPrimary"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/spacing_xs"
                                            android:text="@string/profile_stat_history"
                                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                            android:textColor="?attr/textSecondary" />
                                    </LinearLayout>

                                    <View
                                        android:layout_width="match_parent"
                                        android:layout_height="1dp"
                                        android:layout_marginTop="@dimen/spacing_m"
                                        android:background="?attr/colorOutline" />

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/spacing_s"
                                        android:orientation="vertical">

                                        <TextView
                                            android:id="@+id/tvPlaylistCount"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0"
                                            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                                            android:textColor="?attr/textPrimary"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/spacing_xs"
                                            android:text="@string/profile_stat_playlists"
                                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                            android:textColor="?attr/textSecondary" />
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_m"
                                android:text="@string/profile_sync_hint"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="?attr/textSecondary" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.MusicPlayer.Card.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_m"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_l">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_music_shortcuts"
                            android:textAppearance="@style/TextAppearance.MusicPlayer.SectionTitle"
                            android:textColor="?attr/textPrimary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="@string/profile_music_shortcuts_subtitle"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="?attr/textSecondary" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="@dimen/spacing_m"
                            android:background="?attr/colorOutline" />

                        <LinearLayout
                            android:id="@+id/rowLiked"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_s"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical"
                            android:paddingTop="@dimen/spacing_s"
                            android:paddingBottom="@dimen/spacing_s">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingBottom="@dimen/spacing_s">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    app:cardBackgroundColor="?attr/surfaceColor"
                                    app:cardCornerRadius="20dp"
                                    app:cardElevation="0dp"
                                    app:strokeColor="?attr/dividerColor"
                                    app:strokeWidth="1dp">

                                    <ImageView
                                        android:id="@+id/ivLikedCover"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:contentDescription="@string/favorites_title"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/ic_music_note_24"
                                        android:tint="?attr/brandPrimary" />
                                </com.google.android.material.card.MaterialCardView>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/spacing_m"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvLikedTitle"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/profile_liked_title"
                                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                        android:textColor="?attr/textPrimary"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvLikedMeta"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/spacing_xs"
                                        android:ellipsize="end"
                                        android:maxLines="2"
                                        android:text="@string/profile_liked_empty"
                                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                        android:textColor="?attr/textSecondary" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/spacing_xs"
                                        android:text="@string/profile_liked_hint"
                                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                        android:textColor="?attr/textSecondary" />
                                </LinearLayout>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_gravity="bottom"
                                android:layout_marginStart="80dp"
                                android:background="?attr/colorOutline" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/rowHistory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="vertical"
                            android:paddingTop="@dimen/spacing_s"
                            android:paddingBottom="@dimen/spacing_s">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingBottom="@dimen/spacing_s">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    app:cardBackgroundColor="?attr/surfaceColor"
                                    app:cardCornerRadius="20dp"
                                    app:cardElevation="0dp"
                                    app:strokeColor="?attr/dividerColor"
                                    app:strokeWidth="1dp">

                                    <ImageView
                                        android:id="@+id/ivHistoryCover"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:contentDescription="@string/history_title"
                                        android:scaleType="centerCrop"
                                        android:src="@drawable/ic_now_playing_24"
                                        android:tint="?attr/brandPrimary" />
                                </com.google.android.material.card.MaterialCardView>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/spacing_m"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvHistoryTitle"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/profile_history_title"
                                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                                        android:textColor="?attr/textPrimary"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/tvHistoryMeta"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/spacing_xs"
                                        android:ellipsize="end"
                                        android:maxLines="2"
                                        android:text="@string/profile_history_empty"
                                        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                        android:textColor="?attr/textSecondary" />

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/spacing_xs"
                                        android:text="@string/profile_history_hint"
                                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                        android:textColor="?attr/textSecondary" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</FrameLayout>
