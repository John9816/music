<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_s"
    android:background="@drawable/bg_queue_item"
    android:clickable="true"
    android:focusable="true"
    android:minHeight="52dp"
    android:paddingHorizontal="@dimen/spacing_m"
    android:paddingVertical="@dimen/spacing_sm">

    <ImageView
        android:id="@+id/ivPlaying"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:contentDescription="@string/content_desc_now_playing"
        android:src="@drawable/ic_now_playing_24"
        app:tint="?attr/brandPrimary"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSong"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_s"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/item_song_name_placeholder"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        android:textColor="?attr/textPrimary"
        app:layout_constraintBaseline_toBaselineOf="@id/tvArtist"
        app:layout_constraintEnd_toStartOf="@id/tvDot"
        app:layout_constraintStart_toEndOf="@id/ivPlaying"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvDot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:text="路"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        android:textColor="?attr/textSecondary"
        app:layout_constraintBaseline_toBaselineOf="@id/tvArtist"
        app:layout_constraintEnd_toStartOf="@id/tvArtist"
        app:layout_constraintStart_toEndOf="@id/tvSong" />

    <TextView
        android:id="@+id/tvArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/item_artist_placeholder"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        android:textColor="?attr/textSecondary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnRemove"
        app:layout_constraintStart_toEndOf="@id/tvDot"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnRemove"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_glass_button_circle"
        android:contentDescription="@string/content_desc_remove"
        android:padding="@dimen/spacing_s"
        android:src="@drawable/ic_close_24"
        app:tint="?attr/textSecondary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

