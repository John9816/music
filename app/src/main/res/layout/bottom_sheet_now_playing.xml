<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_now_playing_cymusic_scrim">

    <ImageView
        android:id="@+id/ivBlurBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/viewScrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/spacing_m"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingEnd="@dimen/spacing_m"
        android:paddingBottom="@dimen/spacing_xs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_close"
            android:paddingStart="16dp"
            android:paddingTop="22dp"
            android:paddingEnd="16dp"
            android:paddingBottom="22dp"
            android:src="@drawable/bg_cymusic_sheet_handle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@null" />

        <LinearLayout
            android:id="@+id/layoutSheetMeta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_s"
            android:layout_marginEnd="@dimen/spacing_s"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/btnClose"
            app:layout_constraintEnd_toStartOf="@id/topBarSpacer"
            app:layout_constraintStart_toEndOf="@id/btnClose"
            app:layout_constraintTop_toTopOf="@id/btnClose">

            <TextView
                android:id="@+id/tvSheetTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/current_playing_empty"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/textPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSheetSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/current_playing_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/textSecondary" />

            <TextView
                android:id="@+id/tvSheetMetaDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/now_playing_meta_placeholder"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="?attr/textSecondary" />
        </LinearLayout>

        <View
            android:id="@+id/topBarSpacer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/playerContent"
        layout="@layout/page_now_playing_cover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/controlsBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <LinearLayout
        android:id="@+id/layoutSongMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_cymusic_menu"
        android:elevation="16dp"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.66"
        app:layout_constraintTop_toTopOf="@id/playerContent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:gravity="center_vertical"
            android:text="@string/player_song_options"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="?attr/textSecondary" />

        <TextView
            android:id="@+id/menuShareSong"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/ripple_rect_primary"
            android:gravity="center_vertical"
            app:drawableEndCompat="@drawable/ic_share_24"
            app:drawableTint="?attr/textPrimary"
            android:drawablePadding="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:text="@string/player_share_song"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/textPrimary" />

        <TextView
            android:id="@+id/menuDownloadSong"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/ripple_rect_primary"
            android:gravity="center_vertical"
            app:drawableEndCompat="@drawable/ic_download_24"
            app:drawableTint="?attr/textPrimary"
            android:drawablePadding="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:text="@string/player_download_song"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/textPrimary" />

        <TextView
            android:id="@+id/menuAddPlaylist"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/ripple_rect_primary"
            android:gravity="center_vertical"
            app:drawableEndCompat="@drawable/ic_playlist_24"
            app:drawableTint="?attr/textPrimary"
            android:drawablePadding="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:text="@string/player_add_to_playlist"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/textPrimary" />

        <TextView
            android:id="@+id/menuShowLyrics"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/ripple_rect_primary"
            android:gravity="center_vertical"
            app:drawableEndCompat="@drawable/ic_queue_24"
            app:drawableTint="?attr/textPrimary"
            android:drawablePadding="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:text="@string/player_show_lyrics"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/textPrimary" />

        <TextView
            android:id="@+id/menuShowAlbum"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/ripple_rect_primary"
            android:gravity="center_vertical"
            app:drawableEndCompat="@drawable/ic_music_note_24"
            app:drawableTint="?attr/textPrimary"
            android:drawablePadding="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:text="@string/player_show_album"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/textPrimary" />

        <TextView
            android:id="@+id/menuFavoriteSong"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/ripple_rect_primary"
            android:gravity="center_vertical"
            app:drawableEndCompat="@drawable/ic_favorite_24"
            app:drawableTint="?attr/textPrimary"
            android:drawablePadding="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:text="@string/action_unfavorite"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/textPrimary" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/controlsBar"
        style="@style/Widget.MusicPlayer.Card.Outlined"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_m"
        android:layout_marginEnd="@dimen/spacing_m"
        android:layout_marginBottom="@dimen/spacing_s"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@android:color/transparent"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/progressContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_s"
            android:paddingTop="@dimen/spacing_s"
            android:paddingEnd="@dimen/spacing_s"
            android:paddingBottom="@dimen/spacing_s">

            <LinearLayout
                android:id="@+id/nowPlayingSongInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnFavorite"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/btnFavorite">

                <TextView
                    android:id="@+id/tvControlSongTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="?attr/textPrimary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvControlSongArtist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="?attr/textSecondary" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnFavorite"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="0dp"
                android:background="@drawable/ripple_circular_primary"
                android:contentDescription="@string/content_desc_more"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_more_vert_24"
                app:layout_constraintBottom_toBottomOf="@id/nowPlayingSongInfo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/nowPlayingSongInfo"
                app:tint="?attr/textPrimary" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:value="0"
                android:valueFrom="0"
                android:valueTo="1"
                app:haloRadius="0dp"
                app:labelBehavior="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/nowPlayingSongInfo"
                app:thumbRadius="4dp"
                app:thumbStrokeWidth="0dp"
                app:trackHeight="3dp" />

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-4dp"
                android:includeFontPadding="false"
                android:text="@string/time_zero"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="?attr/textSecondary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sliderProgress" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-4dp"
                android:includeFontPadding="false"
                android:text="@string/time_zero"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="?attr/textSecondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sliderProgress" />

            <!-- Primary transport: previous / play / next -->
            <LinearLayout
                android:id="@+id/controlRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:layout_marginTop="@dimen/spacing_s"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvCurrentTime">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <ImageButton
                        android:id="@+id/btnPrev"
                        android:layout_width="@dimen/now_playing_secondary_control_size"
                        android:layout_height="@dimen/now_playing_secondary_control_size"
                        android:layout_gravity="center"
                        android:background="@drawable/ripple_circular_primary"
                        android:contentDescription="@string/content_desc_previous"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_skip_previous_24"
                        app:tint="?attr/textSecondary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <ImageButton
                        android:id="@+id/btnPlayPause"
                        android:layout_width="@dimen/now_playing_primary_control_size"
                        android:layout_height="@dimen/now_playing_primary_control_size"
                        android:layout_gravity="center"
                        android:background="@drawable/ripple_circular_primary"
                        android:contentDescription="@string/content_desc_play_pause"
                        android:padding="14dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_pause_24"
                        app:tint="?attr/textPrimary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <ImageButton
                        android:id="@+id/btnNext"
                        android:layout_width="@dimen/now_playing_secondary_control_size"
                        android:layout_height="@dimen/now_playing_secondary_control_size"
                        android:layout_gravity="center"
                        android:background="@drawable/ripple_circular_primary"
                        android:contentDescription="@string/content_desc_next"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_skip_next_24"
                        app:tint="?attr/textSecondary" />
                </FrameLayout>

            </LinearLayout>

            <!-- Secondary: favorite / mode / queue / quality (fixed icon size, centered cells) -->
            <LinearLayout
                android:id="@+id/secondaryControlRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/controlRow">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <ImageButton
                        android:id="@+id/btnLyrics"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/action_favorite"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_favorite_24"
                        app:tint="?attr/textSecondary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <ImageButton
                        android:id="@+id/btnPlayMode"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/content_desc_repeat"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_repeat_24"
                        app:tint="?attr/textSecondary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <ImageButton
                        android:id="@+id/btnQueue"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/content_desc_queue"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_queue_24"
                        app:tint="?attr/textSecondary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAudioQuality"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:text="@string/settings_audio_quality"
                        android:textAllCaps="false"
                        android:textSize="11sp"
                        app:backgroundTint="@android:color/transparent"
                        app:icon="@drawable/ic_settings_24"
                        app:iconGravity="textStart"
                        app:iconPadding="2dp"
                        app:iconSize="18dp"
                        app:iconTint="?attr/textSecondary"
                        android:textColor="?attr/textSecondary"
                        app:strokeWidth="0dp" />
                </FrameLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
