<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/pageBackground">

    <ImageView
        android:id="@+id/ivBlurBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/current_playing_title"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/viewScrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="?attr/pageBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/spacing_m"
        android:paddingTop="@dimen/spacing_m"
        android:paddingEnd="@dimen/spacing_m"
        android:paddingBottom="@dimen/spacing_s"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_close"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_down_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/textPrimary" />

        <TextView
            android:id="@+id/tvSheetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/current_playing_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="?attr/textPrimary"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnClose"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnClose" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/playerContent"
        layout="@layout/page_now_playing_cover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/controlsBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/controlsBar"
        style="@style/Widget.MusicPlayer.Card.Outlined"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_m"
        android:layout_marginEnd="@dimen/spacing_m"
        android:layout_marginBottom="@dimen/spacing_m"
        app:cardBackgroundColor="?attr/surfaceColor"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="?attr/dividerColor"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/progressContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_m"
            android:paddingTop="@dimen/spacing_m"
            android:paddingEnd="@dimen/spacing_m"
            android:paddingBottom="@dimen/spacing_m">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAudioQuality"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:text="超清母带"
                android:textAllCaps="false"
                android:textSize="12sp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="17dp"
                app:icon="@drawable/ic_settings_24"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:iconTint="?attr/textPrimary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeWidth="0dp" />

            <ImageButton
                android:id="@+id/btnFavorite"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_favorite"
                android:padding="6dp"
                android:src="@drawable/ic_favorite_24"
                app:layout_constraintBottom_toBottomOf="@id/btnAudioQuality"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/btnAudioQuality"
                app:tint="?attr/textSecondary" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:value="0"
                android:valueFrom="0"
                android:valueTo="1"
                app:haloRadius="18dp"
                app:labelBehavior="floating"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnAudioQuality"
                app:thumbRadius="7dp"
                app:trackHeight="4dp" />

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="00:00"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="?attr/textSecondary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sliderProgress" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="00:00"
                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                android:textColor="?attr/textSecondary"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sliderProgress" />

            <LinearLayout
                android:id="@+id/controlRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="5"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvCurrentTime">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <ImageButton
                        android:id="@+id/btnPlayMode"
                        android:layout_width="@dimen/now_playing_secondary_control_size"
                        android:layout_height="@dimen/now_playing_secondary_control_size"
                        android:layout_gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/content_desc_shuffle"
                        android:padding="10dp"
                        android:src="@drawable/ic_shuffle_24"
                        app:tint="?attr/textSecondary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <ImageButton
                        android:id="@+id/btnPrev"
                        android:layout_width="@dimen/now_playing_secondary_control_size"
                        android:layout_height="@dimen/now_playing_secondary_control_size"
                        android:layout_gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/content_desc_previous"
                        android:padding="10dp"
                        android:src="@drawable/ic_skip_previous_24"
                        app:tint="?attr/textSecondary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <ImageButton
                        android:id="@+id/btnPlayPause"
                        android:layout_width="@dimen/now_playing_primary_control_size"
                        android:layout_height="@dimen/now_playing_primary_control_size"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_toolbar_action_button"
                        android:contentDescription="@string/content_desc_play_pause"
                        android:padding="14dp"
                        android:src="@drawable/ic_pause_24"
                        app:tint="?attr/textPrimary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <ImageButton
                        android:id="@+id/btnNext"
                        android:layout_width="@dimen/now_playing_secondary_control_size"
                        android:layout_height="@dimen/now_playing_secondary_control_size"
                        android:layout_gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/content_desc_next"
                        android:padding="10dp"
                        android:src="@drawable/ic_skip_next_24"
                        app:tint="?attr/textSecondary" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:foregroundGravity="center">

                    <ImageButton
                        android:id="@+id/btnQueue"
                        android:layout_width="@dimen/now_playing_secondary_control_size"
                        android:layout_height="@dimen/now_playing_secondary_control_size"
                        android:layout_gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/content_desc_queue"
                        android:padding="10dp"
                        android:src="@drawable/ic_queue_24"
                        app:tint="?attr/textSecondary" />
                </FrameLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
