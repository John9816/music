<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/pageBackground">

    <ImageView
        android:id="@+id/ivBlurBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.5"
        android:contentDescription="@string/current_playing_title"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/viewScrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="?attr/pageBackground"
        android:alpha="0.72"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_m"
        android:paddingTop="@dimen/spacing_m"
        android:paddingEnd="@dimen/spacing_s"
        android:paddingBottom="@dimen/spacing_s"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_close"
            android:padding="@dimen/spacing_s"
            android:src="@drawable/ic_chevron_down_24"
            android:tint="?attr/textSecondary" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <ViewFlipper
        android:id="@+id/vfContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:inAnimation="@android:anim/fade_in"
        android:outAnimation="@android:anim/fade_out"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="@dimen/spacing_m"
            android:paddingTop="@dimen/spacing_s"
            android:paddingEnd="@dimen/spacing_m"
            android:paddingBottom="@dimen/spacing_m">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCoverBig"
                    android:layout_width="308dp"
                    android:layout_height="308dp"
                    android:layout_gravity="center"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:id="@+id/ivCoverBig"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/current_playing_title"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_music_note_24"
                        android:tint="?attr/brandPrimary" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <TextView
                android:id="@+id/tvTitleBig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@string/current_playing_empty"
                android:textAppearance="@style/TextAppearance.MusicPlayer.HeroTitle"
                android:textColor="?attr/textPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvArtistBig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/current_playing_hint"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/textSecondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/lyricsPage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="@dimen/spacing_m"
            android:paddingBottom="@dimen/spacing_m">

            <ImageView
                android:id="@+id/ivCoverSmall"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                android:contentDescription="@string/current_playing_title"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note_24"
                android:tint="?attr/brandPrimary" />

            <TextView
                android:id="@+id/tvTitleSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:text="@string/current_playing_empty"
                android:textAlignment="center"
                android:textAppearance="@style/TextAppearance.MusicPlayer.SectionTitle"
                android:textColor="?attr/textPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvArtistSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="@string/current_playing_hint"
                android:textAlignment="center"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="?attr/textSecondary" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="@dimen/spacing_xl">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLyrics"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:paddingVertical="@dimen/spacing_m"
                    android:scrollbars="none" />

                <TextView
                    android:id="@+id/tvLyricsPlain"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:lineSpacingExtra="6dp"
                    android:padding="@dimen/spacing_m"
                    android:text="@string/lyrics_placeholder"
                    android:textAlignment="center"
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="?attr/textSecondary"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>
    </ViewFlipper>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/progressContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_m"
        android:layout_marginBottom="@dimen/spacing_s"
        app:layout_constraintBottom_toTopOf="@id/controlsBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnFavorite"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_favorite"
            android:padding="5dp"
            android:src="@drawable/ic_favorite_24"
            android:tint="?attr/textSecondary"
            app:layout_constraintBottom_toTopOf="@id/sliderProgress"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:value="0"
            android:valueFrom="0"
            android:valueTo="1"
            app:labelBehavior="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnFavorite" />

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="00:00"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="?attr/textSecondary"
            app:layout_constraintBottom_toBottomOf="@id/btnAudioQuality"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnAudioQuality" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAudioQuality"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginTop="2dp"
            android:minWidth="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="超清母带"
            android:textAllCaps="false"
            android:textColor="?attr/textPrimary"
            android:textSize="12sp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="17dp"
            app:icon="@drawable/ic_settings_24"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconTint="?attr/textPrimary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/sliderProgress"
            app:strokeWidth="0dp" />

        <TextView
            android:id="@+id/tvTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="00:00"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="?attr/textSecondary"
            app:layout_constraintBottom_toBottomOf="@id/btnAudioQuality"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnAudioQuality" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/controlsBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_m"
        android:layout_marginBottom="@dimen/spacing_m"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/btnPlayMode"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_shuffle"
                android:padding="5dp"
                android:src="@drawable/ic_shuffle_24"
                android:tint="?attr/textSecondary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_previous"
                android:padding="5dp"
                android:src="@drawable/ic_skip_previous_24"
                android:tint="?attr/textSecondary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnPlayPause"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_toolbar_action_button"
                android:contentDescription="@string/content_desc_play_pause"
                android:padding="10dp"
                android:src="@drawable/ic_pause_24"
                android:tint="?attr/textPrimary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_next"
                android:padding="5dp"
                android:src="@drawable/ic_skip_next_24"
                android:tint="?attr/textSecondary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnPlayPause"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/btnQueue"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/content_desc_queue"
                android:padding="5dp"
                android:src="@drawable/ic_queue_24"
                android:tint="?attr/textSecondary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnNext"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>

