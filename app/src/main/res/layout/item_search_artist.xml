<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_song_item"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minHeight="@dimen/song_row_min_height"
    android:orientation="horizontal"
    android:paddingStart="@dimen/spacing_xs"
    android:paddingTop="@dimen/song_row_vertical_padding"
    android:paddingEnd="@dimen/spacing_m"
    android:paddingBottom="@dimen/song_row_vertical_padding">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="@dimen/song_cover_size"
        android:layout_height="@dimen/song_cover_size"
        app:cardBackgroundColor="?attr/surfaceAltColor"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/search_type_artists"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person_24"
            app:tint="?attr/brandPrimary" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvArtistName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/textPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvArtistMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/textSecondary"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
